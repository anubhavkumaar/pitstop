rules_version = '2';

// ──────────────────────────────────────────────────────────────
// Pit Stop — Firestore security rules
//
// Identity model:
//   - "Bootstrap owner" — the UID listed in `isBootstrapOwner()` below.
//     This is the very first admin and a permanent safety net so /admin is
//     never lockable. All other admins live in pitstop_users with role='admin'.
//   - Subsequent admins / crew are created via /admin's Users panel and stored
//     as docs under pitstop_users/{uid} with field `role: 'admin' | 'crew' | 'blocked'`.
// ──────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapOwner() {
      return signedIn()
        && request.auth.uid in [
          '9Fm4u9BgskRYczz4U7xq93DEZjx2'
        ];
    }

    function userRole() {
      return exists(/databases/$(database)/documents/pitstop_users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/pitstop_users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return isBootstrapOwner() || (signedIn() && userRole() in ['admin', 'management']);
    }

    function isStaff() {
      return isBootstrapOwner()
        || (signedIn() && userRole() in ['admin', 'management', 'crew']);
    }

    // Narrower than isAdmin() on purpose — editing/deleting a giveaway entry
    // outright (not just flipping a draw result) is management-only.
    function isManagementOnly() {
      return isBootstrapOwner() || (signedIn() && userRole() == 'management');
    }

    // Managed user accounts. Anyone can read their *own* doc; only management
    // can read the full roster or create / change roles / delete accounts —
    // narrower than isAdmin() on purpose, so a plain admin can't grant itself
    // (or anyone else) more access.
    match /pitstop_users/{userId} {
      allow read:   if signedIn() && (request.auth.uid == userId || isManagementOnly());
      allow create, update, delete: if isManagementOnly();
    }

    // Plaintext password mirror — lets management reset another account's
    // password client-side (re-login as that user via the secondary auth app,
    // then updatePassword), avoiding a server/Admin-SDK dependency. Management
    // only, never readable by the account holders themselves.
    match /pitstop_user_secrets/{userId} {
      allow read, write: if isManagementOnly();
    }

    // Secrets / API tokens (e.g. vgy.me userkey for uploads).
    // ADMINS ONLY — never exposed to anonymous visitors.
    match /pitstop_secrets/{doc} {
      allow read, write: if isAdmin();
    }

    // The Google Sheets backup webhook URL specifically also needs to be
    // readable by whichever roles actually issue giveaway tickets (they're
    // the only ones who trigger a write to it) — write stays admin-only.
    match /pitstop_secrets/sheets {
      allow read: if signedIn() && userRole() in ['crew', 'bennys', 'soochi', 'membership'];
    }

    // Public booking inbox — anyone can submit; only staff can read/update; admin can delete.
    match /pitstop_requests/{doc} {
      allow create: if true;
      allow read:   if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Public-facing roster — admin-managed.
    match /pitstop_roster/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Site config (pricing, taglines, location). Admin-only writes.
    match /pitstop_config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Work log — public portfolio of completed jobs.
    // Anyone can read. Staff (crew or admin) can create / update / delete.
    match /pitstop_logs/{doc} {
      allow read:   if true;
      allow create, update, delete: if isStaff();
    }

    // Gallery — staff post photos of happy customers/cars; public read.
    match /pitstop_gallery/{doc} {
      allow read:                if true;
      allow create, update, delete: if isStaff();
    }

    // Customer reviews — anyone can submit, only approved ones are public.
    // Staff can read everything (for moderation) and update/delete.
    match /pitstop_reviews/{doc} {
      allow create: if true;
      allow read:   if resource.data.approved == true || isStaff();
      allow update, delete: if isStaff();
    }

    // Benny's launch giveaway tickets — one doc per ticket (a name buying twice
    // gets two docs). Three independent channels: 'repair' (Benny's crew),
    // 'food' (Soochi, an external partner), and 'membership' (membership sales).
    // Write access is locked per-channel so no side can issue tickets into
    // another's pool; only admins can ever flip `won` (the live spin-wheel draw).
    match /bennys_tokens/{doc} {
      allow read: if isAdmin()
        || (signedIn() && userRole() in ['crew', 'bennys', 'soochi', 'membership']);

      allow create: if request.resource.data.won == false && (
        isAdmin()
        || ((userRole() == 'crew' || userRole() == 'bennys') && request.resource.data.channel == 'repair')
        || (userRole() == 'soochi' && request.resource.data.channel == 'food')
        || (userRole() in ['membership', 'bennys'] && request.resource.data.channel == 'membership')
        // PD & EMS membership pools — same issuers as regular memberships.
        || (userRole() in ['membership', 'bennys'] && request.resource.data.channel in ['pd', 'ems'])
      );

      // Draw-tool result flips (won / wonPrize / wonAt only) stay open to any
      // admin or management account; editing the entry itself (name, note —
      // anything else) is management-only.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['won', 'wonPrize', 'wonAt']);
      allow update: if isManagementOnly();
      allow delete: if isManagementOnly();
    }

    // Audit trail for giveaway entries (created / edited / removed). Written by
    // whoever performs the action — that includes the ticket-issuing roles
    // ('bennys', 'soochi', 'membership'), who aren't isStaff() but still need to
    // log their own issuances, or the entry silently never appears in the log.
    // Only management can ever read it back. Immutable — no update/delete, ever.
    match /bennys_audit_log/{doc} {
      allow create: if isStaff()
        || (signedIn() && userRole() in ['bennys', 'soochi', 'membership']);
      allow read:   if isManagementOnly();
      allow update, delete: if false;
    }

    // Memberships register — real, ongoing memberships (14-day validity, renewed
    // in place). Issued/managed by the same people as the old membership tickets
    // (admins + membership/bennys crew); deleting a record is management-only.
    match /pitstop_memberships/{doc} {
      allow read: if isStaff()
        || (signedIn() && userRole() in ['membership', 'bennys']);
      allow create, update: if isAdmin()
        || (signedIn() && userRole() in ['membership', 'bennys']);
      allow delete: if isManagementOnly();
    }

    // Default deny — anything not matched above is rejected.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
